{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "dotclaude project settings — only loaded when CWD is ~/dotclaude/. Per-machine overrides live in settings.local.json (gitignored).",

  "theme": "dark-ansi",

  "statusLine": {
    "type": "command",
    "command": "node $CLAUDE_PROJECT_DIR/statusline.mjs"
  },

  "permissions": {
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/tmp"
    ],
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(gh repo view*)",
      "Bash(gh issue view*)",
      "Bash(gh pr view*)",
      "Bash(gh api*)"
    ]
  },

  "skipDangerousModePermissionPrompt": true,

  "_mcp_servers_note": "MCP server registration goes here when activated. See mcp/README.md for the inventory and install steps.",

  "mcpServers": {},

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-load-handoff.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-end-write-handoff.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-secrets-scan.sh" }
        ]
      }
    ]
  }
}
